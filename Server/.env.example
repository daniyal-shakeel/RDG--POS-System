# ==============================
# Application
# ==============================
PORT=5000
NODE_ENV=development

# ==============================
# MongoDB (Local)
# ==============================
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=your-mongo-user
MONGODB_PASSWORD=your-mongo-password
MONGODB_AUTH_SOURCE=admin

# Full Mongo URI (Dev)
MONGO_URI=mongodb://localhost:27017/your-database-name

# ==============================
# Redis (Local)
# ==============================
REDIS_URL=redis://localhost:6379

# ==============================
# JWT
# ==============================
JWT_SECRET=your-very-strong-random-jwt-secret

# ==============================
# Super Admin
# ==============================
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=strong-admin-password

# ==============================
# Frontend URL
# ==============================
FRONTEND_URL=https://your-frontend-url.com

# ==============================
# Production (Example Only)
# ==============================
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database
# REDIS_URL=redis://:password@host:port

# ==============================
# MRPeasy Configuration
# ==============================
MRPEASY_ENABLED=false
MRPEASY_USE_MOCK=true
MRPEASY_BASE_URL=https://app.mrpeasy.com/rest/v1
MRPEASY_API_KEY=your-mrpeasy-api-key
MRPEASY_ACCESS_KEY=your-mrpeasy-access-key
MRPEASY_TIMEOUT_MS=10000